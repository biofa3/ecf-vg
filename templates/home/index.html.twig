{% extends 'base.html.twig' %}

{% block title %}Accueil - Vite & Gourmand{% endblock %}

{% block body %}

    <div id="myCarousel" class="carousel slide mb-6" data-bs-ride="carousel" aria-label="Diaporama Vite &amp; Gourmand" role="region">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#myCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#myCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#myCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>
      <div class="carousel-inner">
    <!-- Slide 1 : active -->
    <div class="carousel-item active">
        <img src="../assets/images/caroussel1.jpg" class="d-block w-100" alt="Cuisine du terroir bordelais" style="height: 100vh; object-fit: cover;">
        <div class="container">
            <div class="carousel-caption text-start">
                <h1>La cuisine du terroir bordelais.</h1>

                <p class="opacity-75">Des plats généreux et savoureux, préparés avec des produits locaux sélectionnés avec soin.</p>
                <p><a class="btn btn-lg btn-primary" href="{{ path('app_menus') }}">Découvrir notre menu</a></p>
            </div>
        </div>
    </div>

    <!-- Slide 2 -->
    <div class="carousel-item">
        <img src="../assets/images/caroussel2.jpg" class="d-block w-100" alt="Événements traiteur" style="height: 100vh; object-fit: cover;">
        <div class="container">
            <div class="carousel-caption">
                <h2>Vos événements, notre passion.</h2>
                <p>Mariages, repas d'entreprise, anniversaires… Nous prenons en charge tous vos événements avec sérieux et gourmandise.</p>
                <p><a class="btn btn-lg btn-primary" href="{{ path('app_menus') }}">Découvrir notre menu</a></p>
            </div>
        </div>
    </div>

    <!-- Slide 3 -->
    <div class="carousel-item">
        <img src="../assets/images/caroussel3.jpg" class="d-block w-100" alt="25 ans de savoir-faire" style="height: 100vh; object-fit: cover;">
        <div class="container">
            <div class="carousel-caption text-end">
                <h2>25 ans de savoir-faire.</h2>
                <p>Depuis 1999, Vite & Gourmand met son expertise au service de votre table.</p>
                <p><a class="btn btn-lg btn-primary" href="{{ path('app_menus') }}">Découvrir notre menu</a></p>
            </div>
        </div>
    </div>
</div>
    </div>

    <div class="container marketing">

        <div class="row">
            <div class="col-lg-4">


                <img src="../assets/images/badge.png" class="rounded-circle" width="140" height="140" alt="Produits locaux">                <h2 class="fw-normal">Produits locaux</h2>

                <p>Nous travaillons exclusivement avec des producteurs girondins pour vous garantir des ingrédients frais et de saison.</p>
                
            </div>
            <div class="col-lg-4">
                <img src="../assets/images/customer-review.png" class="rounded-circle" width="140" height="140" alt="Service client">                
                <h2 class="fw-normal">Satisfait ou remboursé</h2>
                <p>Votre satisfaction est notre priorité… Chaque prestation est adaptée à vos besoins et à votre budget.</p>
               
            </div>
            <div class="col-lg-4">
                <img src="../assets/images/livraison-rapide.png" class="rounded-circle" width="140" height="140" alt="Livraison à domicile">                <h2 class="fw-normal">Livraison à domicile</h2>
                <p>Profitez de notre service de livraison sur Bordeaux et sa métropole, du lundi au samedi.</p>
                
            </div>
        </div>

        <hr class="featurette-divider">
        <div class="row featurette">
            <div class="col-md-7">
                <h2 class="featurette-heading fw-normal lh-1">Présentation de  <span class="text-body-secondary">l'entreprise</span></h2>
                <p class="lead"> Nous sommes une entreprise constituée de deux personnes, Julie et José. Elle existe 
depuis 25 ans à Bordeaux, et propose des prestations pour tout événement (simple repas 
comme Noel ou encore Pâques) au travers d’un menu en constante évolution. Chaque plat est préparé le jour même, avec des recettes transmises de génération en génération et revisitées avec modernité.</p>
            </div>
            <div class="col-md-5">
                <img src="../assets/images/jj.jpg" 
     class="bd-placeholder-img bd-placeholder-img-lg featurette-image img-fluid mx-auto" 
     width="500" height="500"
     alt="Julie et José, les fondateurs de Vite et Gourmand">
            </div>
        </div>

        <hr class="featurette-divider">

        <div class="row featurette">
            <div class="col-md-7 order-md-2">
                <h2 class="featurette-heading fw-normal lh-1">Vos événements méritent le meilleur. <span class="text-body-secondary">On s'en occupe.</span></h2>
                <p class="lead">De la conception du menu à la mise en place sur place, notre équipe gère tout pour que vous puissiez profiter pleinement de vos invités.</p>
            </div>
            <div class="col-md-5 order-md-1">
                <img src="../assets/images/traiteur.jpg"  width="500" height="350" alt="Vos évènements méritent le meilleur">               
            </div>
        </div>

        <hr class="featurette-divider">

        <div class="row featurette">
            <div class="col-md-7">
                <h2 class="featurette-heading fw-normal lh-1">25 ans d'expérience. <span class="text-body-secondary">Et ça se goûte.</span></h2>
                <p class="lead">Depuis 1999, nous avons régalé des milliers de convives. Chaque assiette est le reflet de notre passion pour la bonne cuisine bordelaise.</p>
            </div>
            <div class="col-md-5">
                <img src="../assets/images/traiteur4.jpg"  width="500" height="350" alt="Vos évènements méritent le meilleur">               
            </div>
        </div>

        {% if avis is not empty %}
        <hr class="featurette-divider">
        <div class="py-4">
            <h2 class="fw-normal text-center mb-4">Ce que disent nos clients</h2>
            <div class="row g-4">
                {% for unAvis in avis %}
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4">
                            <div class="text-warning mb-2" aria-label="Note : {{ unAvis.note }} sur 5">
                                {% for i in 1..unAvis.note %}⭐{% endfor %}
                            </div>
                            {% if unAvis.description %}
                                <p class="mb-3">"{{ unAvis.description }}"</p>
                            {% endif %}
                            <small class="fw-bold text-muted">
                                {{ unAvis.commande.utilisateur.prenom }} {{ unAvis.commande.utilisateur.nom|first|upper }}.
                            </small><br>
                            <small class="text-muted">{{ unAvis.commande.menu.titre }}</small>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

    </div>

{% endblock %}