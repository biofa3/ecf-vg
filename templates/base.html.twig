<!doctype html>
<html lang="fr" data-bs-theme="auto">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Vite &amp; Gourmand - Traiteur Bordelais{% endblock %}</title>
    <meta name="description" content="Spécialisés dans la cuisine du terroir depuis 25 ans">

    <link rel="stylesheet" href="{{ asset('/assets/css/style.css') }}">
    <link href="{{ asset('/assets/css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('/assets/css/carousel.css') }}" rel="stylesheet">
    <link href="{{ asset('/assets/css/custom.css') }}" rel="stylesheet">
    <script src="https://unpkg.com/feather-icons" defer></script>
</head>
<body>

<header data-bs-theme="dark">
    <nav class="navbar navbar-expand-md navbar-dark fixed-top bg-dark">
        <div class="container-fluid">
            <img src="../assets/images/logo.png" alt="Logo Vite & Gourmand" width="150" height="150" class="d-inline-block align-text-top me-2">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarCollapse">
                <ul class="navbar-nav mx-auto mb-2 mb-md-0">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="http://127.0.0.1:8000/">Accueil</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="http://127.0.0.1:8000/menus">Nos formules</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_contact') }}">Contact</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    {% if app.user %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_espace_admin') }}" class="text-white text-decoration-none small">
                                <i data-feather="user" style="width:18px"></i> {{ app.user.prenom }}
                            </a>
                        {% elseif is_granted('ROLE_EMPLOYE') %}
                            <a href="{{ path('app_espace_employe') }}" class="text-white text-decoration-none small">
                                <i data-feather="user" style="width:18px"></i> {{ app.user.prenom }}
                            </a>
                        {% else %}
                            <a href="{{ path('app_espace_utilisateur') }}" class="text-white text-decoration-none small">
                                <i data-feather="user" style="width:18px"></i> {{ app.user.prenom }}
                            </a>
                        {% endif %}
                        <a href="{{ path('app_logout') }}" class="text-white-50 text-decoration-none small">Déconnexion</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-sm">Connexion</a>
                        <a href="{{ path('app_register') }}" class="btn btn-success btn-sm">Inscription</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </nav>
</header>

<main style="padding-top: 56px;">

    {% block body %}{% endblock %}

    <footer class="container">
        <p>&copy; 2017–2024 Vite &amp; Gourmand <a href="#">CGV</a> &middot; <a href="#">CGU</a></p>
    </footer>
</main>

<script src="{{ asset('/assets/js/bootstrap.bundle.min.js') }}"></script>
<script src="{{ asset('/assets/js/global.js') }}"></script>
</body>
</html>