{% extends 'base.html.twig' %}

{% block title %}Menus - Espace Employé{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;font-size:1.5rem;">
                        <i data-feather="briefcase"></i>
                    </div>
                    <h6 class="fw-bold mb-0">Espace Employé</h6>
                    <small class="text-muted">{{ app.user.prenom }} {{ app.user.nom }}</small>
                </div>
                <div class="list-group list-group-flush rounded-bottom">
                    <a href="{{ path('app_espace_employe') }}" class="list-group-item list-group-item-action">
                        <i data-feather="list" class="me-2"></i> Commandes
                    </a>
                    <a href="{{ path('app_employe_menus') }}" class="list-group-item list-group-item-action active">
                        <i data-feather="book-open" class="me-2"></i> Menus
                    </a>
                    <a href="{{ path('app_employe_avis') }}" class="list-group-item list-group-item-action">
                        <i data-feather="star" class="me-2"></i> Avis clients
                    </a>
                    <a href="{{ path('app_logout') }}" class="list-group-item list-group-item-action text-danger">
                        <i data-feather="log-out" class="me-2"></i> Déconnexion
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <h2 class="fw-bold mb-4 mt-4">Menus</h2>
            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" aria-label="Liste des menus">
                        <caption class="visually-hidden">Liste des menus disponibles</caption>
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Titre</th>
                                <th scope="col">Thème</th>
                                <th scope="col">Prix/pers.</th>
                                <th scope="col">Min pers.</th>
                                <th scope="col">Conditions</th>
                                <th scope="col"><span class="visually-hidden">Actions</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for menu in menus %}
                            <tr>
                                <td class="fw-bold">{{ menu.titre }}</td>
                                <td>{{ menu.theme ? menu.theme.libelle : '-' }}</td>
                                <td>{{ menu.prixParPersonne }} €</td>
                                <td>{{ menu.nombrePersonneMinimum }}</td>
                                <td>
                                    {% if menu.conditions %}
                                        <span class="badge bg-success">Renseignées</span>
                                    {% else %}
                                        <span class="badge bg-warning text-dark">Manquantes</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <a href="{{ path('app_employe_menu_edit', {id: menu.id}) }}"
                                       class="btn btn-sm btn-outline-primary"
                                       aria-label="Modifier le menu {{ menu.titre }}">
                                        <i data-feather="edit-2" style="width:14px" aria-hidden="true"></i> Modifier
                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
