{% extends 'base.html.twig' %}

{% block title %}Commandes - Administration{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;font-size:1.5rem;">
                        <i data-feather="shield"></i>
                    </div>
                    <h6 class="fw-bold mb-0">Administration</h6>
                    <small class="text-muted">{{ app.user.prenom }} {{ app.user.nom }}</small>
                </div>
                <div class="list-group list-group-flush rounded-bottom">
                    <a href="{{ path('app_espace_admin') }}" class="list-group-item list-group-item-action">
                        <i data-feather="bar-chart-2" class="me-2"></i> Tableau de bord
                    </a>
                    <a href="{{ path('app_admin_commandes') }}" class="list-group-item list-group-item-action active">
                        <i data-feather="shopping-bag" class="me-2"></i> Commandes
                    </a>
                    <a href="{{ path('app_admin_menus') }}" class="list-group-item list-group-item-action">
                        <i data-feather="book-open" class="me-2"></i> Menus
                    </a>
                    <a href="{{ path('app_admin_employe_new') }}" class="list-group-item list-group-item-action">
                        <i data-feather="user-plus" class="me-2"></i> CrÃ©er un employÃ©
                    </a>
                    <a href="{{ path('app_admin_avis') }}" class="list-group-item list-group-item-action">
                        <i data-feather="star" class="me-2"></i> Avis clients
                    </a>
                    <a href="{{ path('app_admin_stats') }}" class="list-group-item list-group-item-action">
                        <i data-feather="pie-chart" class="me-2"></i> Statistiques
                    </a>
                    <a href="{{ path('app_logout') }}" class="list-group-item list-group-item-action text-danger">
                        <i data-feather="log-out" class="me-2"></i> DÃ©connexion
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            <h2 class="fw-bold mb-4 mt-3">Gestion des commandes</h2>

            {% if commandes is empty %}
                <div class="card border-0 shadow-sm text-center py-5">
                    <p class="text-muted">Aucune commande pour le moment.</p>
                </div>
            {% else %}
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" aria-label="Liste des commandes">
                            <caption class="visually-hidden">Liste des commandes clients</caption>
                            <thead class="table-light">
                                <tr>
                                    <th scope="col">NÂ° Commande</th>
                                    <th scope="col">Client</th>
                                    <th scope="col">Menu</th>
                                    <th scope="col">Date</th>
                                    <th scope="col">Total</th>
                                    <th scope="col">Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for commande in commandes %}
                                <tr>
                                    <td><small class="text-muted">{{ commande.numeroCommande }}</small></td>
                                    <td>{{ commande.utilisateur.prenom }} {{ commande.utilisateur.nom }}</td>
                                    <td>{{ commande.menu.titre }}</td>
                                    <td>{{ commande.datePrestation|date('d/m/Y') }}</td>
                                    <td>{{ (commande.prixMenu + commande.prixLivraison)|number_format(2, ',', ' ') }} â‚¬</td>
                                    <td>
                                        <form method="post" action="{{ path('app_admin_commande_statut', {id: commande.id}) }}" class="d-flex gap-1" aria-label="Changer le statut de la commande {{ commande.numeroCommande }}">
                                            <label for="statut-{{ commande.id }}" class="visually-hidden">Statut de la commande {{ commande.numeroCommande }}</label>
                                            <select id="statut-{{ commande.id }}" name="statut" class="form-select form-select-sm" style="width:auto">
                                                {% for s in ['en attente', 'acceptée', 'en préparation', 'en cours de livraison', 'en attente du retour de matériel', 'terminée', 'annulée'] %}
                                                    <option value="{{ s }}" {% if commande.statut == s %}selected{% endif %}>{{ s }}</option>
                                                {% endfor %}
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-primary" aria-label="Valider le statut">OK</button>
                                        </form>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

