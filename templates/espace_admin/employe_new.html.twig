{% extends 'base.html.twig' %}

{% block title %}Créer un employé - Administration{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4">Créer un compte employé</h4>

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    <div class="row g-3">
                        <div class="col-md-6">{{ form_row(form.nom) }}</div>
                        <div class="col-md-6">{{ form_row(form.prenom) }}</div>
                        <div class="col-12">{{ form_row(form.email) }}</div>
                        <div class="col-md-6">{{ form_row(form.plainPassword.first) }}</div>
                        <div class="col-md-6">{{ form_row(form.plainPassword.second) }}</div>
                    </div>
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Créer le compte</button>
                        <a href="{{ path('app_espace_admin') }}" class="btn btn-outline-secondary ms-2">Annuler</a>
                    </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
