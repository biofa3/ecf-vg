{% extends 'base.html.twig' %}

{% block title %}Avis clients - Administration{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;font-size:1.5rem;">
                        <i data-feather="shield"></i>
                    </div>
                    <h6 class="fw-bold mb-0">Administration</h6>
                    <small class="text-muted">{{ app.user.prenom }} {{ app.user.nom }}</small>
                </div>
                <div class="list-group list-group-flush rounded-bottom">
                    <a href="{{ path('app_espace_admin') }}" class="list-group-item list-group-item-action">
                        <i data-feather="bar-chart-2" class="me-2"></i> Tableau de bord
                    </a>
                    <a href="{{ path('app_admin_commandes') }}" class="list-group-item list-group-item-action">
                        <i data-feather="shopping-bag" class="me-2"></i> Commandes
                    </a>
                    <a href="{{ path('app_admin_menus') }}" class="list-group-item list-group-item-action">
                        <i data-feather="book-open" class="me-2"></i> Menus
                    </a>
                    <a href="{{ path('app_admin_employe_new') }}" class="list-group-item list-group-item-action">
                        <i data-feather="user-plus" class="me-2"></i> CrÃ©er un employÃ©
                    </a>
                    <a href="{{ path('app_admin_avis') }}" class="list-group-item list-group-item-action active">
                        <i data-feather="star" class="me-2"></i> Avis clients
                    </a>
                    <a href="{{ path('app_admin_stats') }}" class="list-group-item list-group-item-action">
                        <i data-feather="pie-chart" class="me-2"></i> Statistiques
                    </a>
                    <a href="{{ path('app_logout') }}" class="list-group-item list-group-item-action text-danger">
                        <i data-feather="log-out" class="me-2"></i> DÃ©connexion
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            <h2 class="fw-bold mb-4 mt-3">Avis clients</h2>

            {% if avis is empty %}
                <div class="card border-0 shadow-sm text-center py-5">
                    <p class="text-muted">Aucun avis pour le moment.</p>
                </div>
            {% else %}
                {% for unAvis in avis %}
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="fw-bold mb-1">
                                    {{ unAvis.commande.utilisateur.prenom }} {{ unAvis.commande.utilisateur.nom|first|upper }}.
                                    <span class="text-warning ms-2">{% for i in 1..unAvis.note %}â­{% endfor %}</span>
                                </h6>
                                <small class="text-muted">Menu : {{ unAvis.commande.menu.titre }}</small>
                                {% if unAvis.description %}
                                    <p class="mt-2 mb-0">{{ unAvis.description }}</p>
                                {% endif %}
                            </div>
                            <div class="text-end">
                                <span class="badge {% if unAvis.statut == 'publiÃ©' %}bg-success{% elseif unAvis.statut == 'refusÃ©' %}bg-danger{% else %}bg-warning text-dark{% endif %} mb-2">
                                    {{ unAvis.statut }}
                                </span>
                                {% if unAvis.statut == 'en attente' %}
                                <div class="d-flex gap-2 justify-content-end">
                                    <a href="{{ path('app_admin_avis_valider', {id: unAvis.id}) }}" class="btn btn-sm btn-success">Publier</a>
                                    <a href="{{ path('app_admin_avis_refuser', {id: unAvis.id}) }}" class="btn btn-sm btn-outline-danger">Refuser</a>
                                </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

